{
  "name": "daily-poster-packet",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "cloudflare:ensure-resources": "node scripts/ensure-cloudflare-resources.mjs",
    "db:migrate": "wrangler d1 migrations apply daily-poster-packet-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply daily-poster-packet-db --remote",
    "db:seed": "wrangler d1 execute daily-poster-packet-db --local --file=./seed.sql",
    "db:seed:remote": "wrangler d1 execute daily-poster-packet-db --remote --file=./seed.sql",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "hono": "^4.10.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260617.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16",
    "wrangler": "^4.54.0"
  },
  "engines": {
    "node": ">=20"
  }
}
